# Externally reachable base URL (PWA start_url, links).
APP_BASE_URL=http://localhost:3000

# SQLite database file. On Fly: /data/crm.db (persistent volume).
DATABASE_URL=crm.db

# Shared secret for inbound lead webhooks from the Woodchuckers719 site.
# Generate: openssl rand -hex 32   (set the SAME value in both apps)
CRM_WEBHOOK_SECRET=
