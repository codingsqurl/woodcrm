# Externally reachable base URL (PWA start_url, links, OAuth redirect URI).
APP_BASE_URL=http://localhost:3000

# SQLite database file. On Fly: /data/crm.db (persistent volume).
DATABASE_URL=crm.db

# Shared secret for inbound lead webhooks from the Woodchuckers719 site.
# Generate: openssl rand -hex 32   (set the SAME value in both apps)
CRM_WEBHOOK_SECRET=

# Signing key for the stateless session JWT (HS256). REQUIRED — sign-in fails
# closed without it. Generate: openssl rand -hex 32
# Rotating it invalidates every logged-in session (everyone re-signs in).
SESSION_SECRET=

# Google OAuth sign-in. Create a "Web application" OAuth client at
# https://console.cloud.google.com/apis/credentials and add
#   <APP_BASE_URL>/api/auth/google/callback
# as an authorized redirect URI (one entry per environment).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Comma-separated emails allowed to auto-create their user row on first
# Google sign-in. Emails already in the users table always get in.
GOOGLE_ALLOWED_EMAILS=

# Web Push (follow-up reminders + site health alerts). Generate the pair with
# `npm run vapid`. Both required; missing keys mean push is off — fail closed.
# Rotating them invalidates every existing subscription.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact claim in the VAPID JWT (defaults to the shop gmail).
# VAPID_SUBJECT=mailto:woodchuckerstrees719@gmail.com

# The marketing site's health endpoint. Unset = polling off.
SITE_HEALTH_URL=https://woodchuckertrees.com/healthz

# Transactional email (review requests, and later booking reminders + quotes)
# via Resend — https://resend.com/api-keys. Unset = email actions no-op.
# MAIL_FROM must be a verified sender/domain (defaults to Resend's sandbox).
RESEND_API_KEY=
MAIL_FROM=Woodchuckers <hello@woodchuckertrees.com>

# Where the "leave a review" button sends customers. Defaults to the links
# page; set to a direct Google review link to go straight to the stars.
REVIEW_URL=https://woodchuckers-links.fly.dev/

# Shared token for the external uptime checker's webhook:
#   POST <APP_BASE_URL>/api/webhooks/health?token=<value>&status=down
# Generate: openssl rand -hex 32   Unset = endpoint refuses everything.
UPTIME_WEBHOOK_TOKEN=
